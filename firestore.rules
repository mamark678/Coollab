rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check project membership
    function isMember(noteId) {
      let note = get(/databases/$(database)/documents/notes/$(noteId)).data;
      return request.auth != null && (
        note.ownerId == request.auth.uid || 
        request.auth.uid in note.collaborators ||
        exists(/databases/$(database)/documents/projectPermissions/$(noteId + "_" + request.auth.uid))
      );
    }

    // 1. Core Notes & Projects
    match /notes/{noteId} {
      allow read: if true;
      // Allow creation by any authenticated user
      allow create: if request.auth != null;
      // Allow update/delete if they are a member
      allow update, delete: if request.auth != null && isMember(noteId);
      
      // Allow all subcollections (comments, versions, instructions, presence)
      match /{allPaths=**} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // 2. Share Links (CRITICAL FIX: Missing in previous version)
    match /shareLinks/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 3. Project Permissions
    match /projectPermissions/{permId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // 4. User Profiles
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 5. Submissions
    match /submissions/{submissionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 6. Notifications
    match /notifications/{userId}/items/{itemId} {
      allow read, write: if request.auth != null;
    }
  }
}
